{
  "$schema": "../../../../../../node_modules/wrangler/config-schema.json",
  "name": "env-prep-test",
  "main": "worker-setup.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "SetupContainer",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 10
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SETUP_ORCHESTRATOR", "class_name": "SetupOrchestrator" },
      { "name": "SETUP_CONTAINER",    "class_name": "SetupContainer" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["TestEnvPrepSandbox"] },
    { "tag": "v2",
      "new_sqlite_classes": ["PrepOrchestrator", "PrepContainer"],
      "deleted_classes":   ["TestEnvPrepSandbox"]
    },
    { "tag": "v3",
      "new_sqlite_classes": ["SetupOrchestrator", "SetupContainer"],
      "deleted_classes":   ["PrepOrchestrator", "PrepContainer"]
    }
  ],

  "observability": { "enabled": true }
}
