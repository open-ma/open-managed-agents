{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "managed-agents",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "../console/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/v1/*",
      "/auth/*",
      "/auth-info",
      "/health",
      "/linear/*",
      "/linear-setup/*",
      "/agents/runtime/*",
      "/billing-api/*"
    ]
  },

  "rules": [
    { "type": "Text", "globs": ["**/*.html"], "fallthrough": true }
  ],

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  // Public origin of the integrations gateway. apps/main wires this into
  // Linear-triggered sessions as the URL of the OMA-hosted Linear MCP
  // server. Override per env via vars.
  "vars": {
    "INTEGRATIONS_ORIGIN": "https://integrations.openma.dev",
    "TURNSTILE_SITE_KEY": "0x4AAAAAADDow0APKUYcuXMp"
  },

  "r2_buckets": [
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
    // Bytes-of-truth for memory store content. Each memory is keyed
    // <store_id>/<memory_path>. R2 Event Notifications on this bucket
    // route to MEMORY_EVENTS_QUEUE; the queue consumer in this worker
    // reflects writes back to D1 (memories index + memory_versions audit).
    { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
  ],

  // D1 layout (post-shard rollout) — must match OSS apps/main/wrangler.jsonc.
  // ROUTER_DB resolves tenant→shard. AUTH_DB legacy alias = AUTH_DB_00 same id.
  "d1_databases": [
    { "binding": "AUTH_DB",    "database_name": "openma-auth",          "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" },
    { "binding": "ROUTER_DB",  "database_name": "openma-router",        "database_id": "6ddad512-7976-4912-8003-7746ba1e4cb6" },
    { "binding": "AUTH_DB_00", "database_name": "openma-auth",          "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" },
    { "binding": "AUTH_DB_01", "database_name": "openma-auth-shard-01", "database_id": "37a3138c-8d1e-4258-8a0d-e0da511b0175" },
    { "binding": "AUTH_DB_02", "database_name": "openma-auth-shard-02", "database_id": "254c56dc-2a99-4266-87ae-9ff46355eb75" },
    { "binding": "AUTH_DB_03", "database_name": "openma-auth-shard-03", "database_id": "a4f72551-7ce7-4da3-a33e-f4abb00bb86f" }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom" }
    ]
  },

  // Cloudflare Email Service (public beta) — transactional email
  "send_email": [
    { "name": "SEND_EMAIL" }
  ],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Service bindings to agent workers + hosted-only meter.
  // USAGE_METER points at packages/billing/ (entrypoint UsageMeter); the
  // OSS Env declares the duck-typed contract so this binding is purely
  // a hosted-deployment concern — self-host omits.
  "services": [
    { "binding": "SANDBOX_sandbox_default", "service": "sandbox-default" },
    { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" },
    { "binding": "USAGE_METER", "service": "managed-agents-billing", "entrypoint": "UsageMeter" },
    { "binding": "USAGE_METER_HTTP", "service": "managed-agents-billing" }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    },
    {
      "tag": "v2",
      "deleted_classes": ["SessionDO", "Sandbox"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["BuilderSandbox"]
    },
    {
      "tag": "v4",
      "deleted_classes": ["BuilderSandbox"]
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["RuntimeRoom"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true },

  // Analytics Engine for structured error/event metrics. Dataset is created
  // automatically on first write — no dashboard pre-step needed. Query via
  // Cloudflare's SQL API or the Grafana plugin. Schema convention lives in
  // packages/shared/src/metrics.ts (column positions are load-bearing).
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "oma_events" }
  ],

  // Cross-isolate rate limiting via CF Workers Rate Limiting binding.
  // Replaces a per-isolate Map limiter that under-counted N×isolate.
  // CF only supports period 10 or 60 (seconds); pick limits accordingly.
  // namespace_ids are arbitrary tenant-scoped numeric tokens — they only
  // need to be unique within this worker.
  "ratelimits": [
    { "name": "RL_AUTH_IP",         "namespace_id": "1001", "simple": { "limit": 60, "period": 60 } },
    { "name": "RL_AUTH_SEND_IP",    "namespace_id": "1002", "simple": { "limit": 5,  "period": 60 } },
    { "name": "RL_AUTH_SEND_EMAIL", "namespace_id": "1003", "simple": { "limit": 1,  "period": 60 } },
    { "name": "RL_API_USER_WRITE",  "namespace_id": "1004", "simple": { "limit": 60, "period": 60 } },
    { "name": "RL_API_USER_READ",   "namespace_id": "1005", "simple": { "limit": 600,"period": 60 } },
    { "name": "RL_SESSIONS_TENANT", "namespace_id": "1006", "simple": { "limit": 5,  "period": 60 } },
    { "name": "RL_UPLOAD_TENANT",   "namespace_id": "1007", "simple": { "limit": 30, "period": 60 } }
  ],

  // Cloudflare Queue consumer for R2 Event Notifications on MEMORY_BUCKET.
  // R2 fires { action, bucket, object: { key, size, eTag } } per write/delete;
  // the consumer in apps/main/src/queue/memory-events.ts derives store_id+path
  // from the key, dedupes by (store_id, path, etag), and writes:
  //   - memories index row (UPSERT)
  //   - memory_versions audit row (INSERT)
  // R2 → Queue subscription itself is NOT in wrangler — set it up via:
  //   wrangler r2 bucket notification create managed-agents-memory \
  //     --event-type object-create object-delete \
  //     --queue managed-agents-memory-events
  // Local dev: R2 events do NOT fire (CF control-plane feature). REST writes
  // still audit (inline write to D1 in the route handler), but agent FUSE
  // writes are not audited in dev. Documented in README.
  "queues": {
    "consumers": [
      {
        "queue": "managed-agents-memory-events",
        "max_batch_size": 25,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "managed-agents-memory-events-dlq"
      },
      {
        // DLQ subscriber for the main queue above. Captures messages that
        // exhausted retries (D1 outage, malformed key, code regression),
        // logs + records to AE so they don't disappear silently. Handler
        // ALWAYS acks — there's no DLQ-of-DLQ in CF Queues, and a thrown
        // handler here would loop until expiry.
        "queue": "managed-agents-memory-events-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 30,
        "max_retries": 1
      }
    ]
  },

  "triggers": {
    "crons": ["* * * * *"]
  },

  "env": {
    "staging": {
      "name": "managed-agents-staging",
      "vars": {
        "INTEGRATIONS_ORIGIN": "https://integrations.staging.openma.dev"
      },
      "routes": [
        { "pattern": "app.staging.openma.dev", "custom_domain": true }
      ],
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "f91ddab8abe64941bd3ef398b0c187a7" }
      ],
      "d1_databases": [
        { "binding": "AUTH_DB",    "database_name": "openma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "ROUTER_DB",  "database_name": "openma-router-staging",        "database_id": "c238a338-9b6e-40c5-aaaa-48d4fe6dc63d" },
        { "binding": "AUTH_DB_00", "database_name": "openma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "AUTH_DB_01", "database_name": "openma-auth-shard-01-staging", "database_id": "fe6a34d1-cd8a-48a1-bff1-29032026d006" },
        { "binding": "AUTH_DB_02", "database_name": "openma-auth-shard-02-staging", "database_id": "8636a018-8ac6-48c2-ae95-2f70919c8aab" },
        { "binding": "AUTH_DB_03", "database_name": "openma-auth-shard-03-staging", "database_id": "8ce8f17d-7527-4a5a-b097-ce73251be55a" }
      ],
      "r2_buckets": [
        { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory-staging" }
      ],
      // Memory queue consumers intentionally NOT registered here for
      // staging — `managed-agents-lane-mem-anthropic` (lane worker)
      // owns them in this account and CF allows only one consumer per
      // queue. Re-add only if lane is decommissioned.
      "send_email": [
        { "name": "SEND_EMAIL" }
      ],
      "ai": { "binding": "AI" },
      "services": [
        { "binding": "SANDBOX_sandbox_default", "service": "sandbox-default-staging" },
        { "binding": "INTEGRATIONS", "service": "managed-agents-integrations-staging" }
        // USAGE_METER intentionally omitted on staging — packages/billing
        // isn't deployed there. The OSS contract is duck-typed optional,
        // so canStartSandbox/recordUsage soft-skip when binding is absent.
      ],
      "durable_objects": {
        "bindings": [
          { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom" }
        ]
      },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events_staging" }
      ],
      "ratelimits": [
        { "name": "RL_AUTH_IP",         "namespace_id": "2001", "simple": { "limit": 60, "period": 60 } },
        { "name": "RL_AUTH_SEND_IP",    "namespace_id": "2002", "simple": { "limit": 5,  "period": 60 } },
        { "name": "RL_AUTH_SEND_EMAIL", "namespace_id": "2003", "simple": { "limit": 1,  "period": 60 } },
        { "name": "RL_API_USER_WRITE",  "namespace_id": "2004", "simple": { "limit": 60, "period": 60 } },
        { "name": "RL_API_USER_READ",   "namespace_id": "2005", "simple": { "limit": 600,"period": 60 } },
        { "name": "RL_SESSIONS_TENANT", "namespace_id": "2006", "simple": { "limit": 5,  "period": 60 } },
        { "name": "RL_UPLOAD_TENANT",   "namespace_id": "2007", "simple": { "limit": 30, "period": 60 } }
      ]
    }
  }
}
