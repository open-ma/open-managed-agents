{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "managed-agents",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "../console/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "rules": [
    { "type": "Text", "globs": ["**/*.html"], "fallthrough": true }
  ],

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Vectorize for semantic memory search
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "memory-search" }
  ],

  // DinD builder container for building custom environment images
  "containers": [
    {
      "class_name": "BuilderSandbox",
      "image": "docker.io/cloudflare/sandbox:0.7.20",
      "instance_type": "standard",
      "max_instances": 2
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "BUILDER_SANDBOX", "class_name": "BuilderSandbox" }
    ]
  },

  // Service bindings to agent workers
  "services": [
    { "binding": "SANDBOX_sandbox_default", "service": "sandbox-default" }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    },
    {
      "tag": "v2",
      "deleted_classes": ["SessionDO", "Sandbox"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["BuilderSandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true }
}
