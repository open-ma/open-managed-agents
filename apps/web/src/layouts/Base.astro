---
import "../styles/global.css";
import { organizationSchema, websiteSchema } from "../lib/seo";

export interface Props {
  title: string;
  description?: string;
  /** Canonical path under https://www.openma.dev — leading slash. */
  canonical?: string;
  /** og:type. Default "website"; "article" for blog posts. */
  ogType?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  /** Absolute URL to a per-page OG image. Falls back to /og-default.png. */
  ogImage?: string;
  /** Extra JSON-LD blocks to inject (e.g. BlogPosting, BreadcrumbList). */
  schemas?: Array<Record<string, unknown>>;
  /** Comma-separated keywords for the page (used in meta keywords + JSON-LD). */
  keywords?: string;
}

const {
  title,
  description,
  canonical,
  ogType = "website",
  publishedAt,
  updatedAt,
  ogImage,
  schemas = [],
  keywords,
} = Astro.props;

const SITE = "https://www.openma.dev";
// Append " — openma" only when the title doesn't already contain "openma".
// Avoids "openma — openma" on the homepage and the seed posts.
const fullTitle = /openma/i.test(title) ? title : `${title} — openma`;
const desc = description ?? "Open-source meta-harness for AI agents. BYOK, sandboxed cloud or self-host. Make agents real members of your Linear, Slack, GitHub workspaces.";
const url = canonical ? `${SITE}${canonical}` : Astro.url.toString();
const finalOgImage = ogImage ?? `${SITE}/og-default.png`;

const allSchemas = [organizationSchema(), websiteSchema(), ...schemas];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={url} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <!-- Color scheme — let browsers pick chrome that matches our theme. -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ea580c" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#fb923c" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <!-- Theme: system preference with manual override. -->
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t === "dark" || (!t && matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <!-- Fonts: same set Console uses, so cross-domain feels consistent.
         display=swap so text renders before the font lands (avoids CLS). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="openma" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${fullTitle} — open-source meta-harness for AI agents`} />
    {publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {updatedAt && (
      <meta property="article:modified_time" content={updatedAt.toISOString()} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@openma_dev" />
    <meta name="twitter:creator" content="@openma_dev" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={finalOgImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="openma blog" href="/blog/rss.xml" />

    <!-- JSON-LD structured data — Organization + WebSite on every page,
         plus per-page schemas (BlogPosting, BreadcrumbList) injected by callers. -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-bg text-fg">
    <header class="border-b border-[var(--color-border)]">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-fg hover:text-fg" aria-label="openma home">
          <img src="/logo.svg" alt="" class="h-7" width="28" height="28" />
          <span class="font-mono font-bold">openma</span>
        </a>
        <nav class="flex items-center gap-5 text-sm" aria-label="Primary">
          <a href="/blog">Blog</a>
          <a href="https://docs.openma.dev">Docs</a>
          <a href="https://github.com/open-ma/open-managed-agents" target="_blank" rel="noopener">GitHub</a>
          <a
            href="https://openma.dev/login"
            class="px-3 py-1.5 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] font-medium"
            >Sign in</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-20">
      <div class="max-w-5xl mx-auto px-4 py-8 text-sm text-[var(--color-fg-muted)] flex flex-wrap gap-x-8 gap-y-2 justify-between">
        <div>© {new Date().getFullYear()} openma. MIT licensed.</div>
        <nav class="flex gap-5" aria-label="Footer">
          <a href="/blog">Blog</a>
          <a href="https://docs.openma.dev">Docs</a>
          <a href="https://github.com/open-ma/open-managed-agents">GitHub</a>
          <a href="/blog/rss.xml">RSS</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
