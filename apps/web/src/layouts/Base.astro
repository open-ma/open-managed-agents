---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  /** Canonical path under https://openma.dev — leading slash. */
  canonical?: string;
  /** og:type. Default "website"; "article" for blog posts. */
  ogType?: "website" | "article";
  publishedAt?: Date;
}

const { title, description, canonical, ogType = "website", publishedAt } = Astro.props;
const fullTitle = title.includes("openma") ? title : `${title} — openma`;
const desc = description ?? "Open-source meta-harness for AI agents. Run on Cloudflare or self-host.";
const url = canonical ? `https://openma.dev${canonical}` : Astro.url.toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <!-- Theme -->
    <script is:inline>
      // Mirror Console: system preference with manual override.
      const t = localStorage.getItem("theme");
      if (t === "dark" || (!t && matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <!-- Fonts: same set Console uses, so cross-domain feels consistent. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph / Twitter -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="openma" />
    <meta property="og:image" content="https://openma.dev/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    {publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="openma blog" href="/blog/rss.xml" />
  </head>
  <body class="bg-bg text-fg">
    <header class="border-b border-[var(--color-border)]">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-fg hover:text-fg">
          <img src="/logo.svg" alt="openma" class="h-7" />
          <span class="font-mono font-bold">openma</span>
        </a>
        <nav class="flex items-center gap-5 text-sm">
          <a href="/blog">Blog</a>
          <a href="https://docs.openma.dev">Docs</a>
          <a href="https://github.com/open-ma/open-managed-agents" target="_blank" rel="noopener">GitHub</a>
          <a
            href="https://openma.dev/login"
            class="px-3 py-1.5 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] font-medium"
            >Sign in</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-20">
      <div class="max-w-5xl mx-auto px-4 py-8 text-sm text-[var(--color-fg-muted)] flex flex-wrap gap-x-8 gap-y-2 justify-between">
        <div>© {new Date().getFullYear()} openma. MIT licensed.</div>
        <div class="flex gap-5">
          <a href="/blog">Blog</a>
          <a href="https://docs.openma.dev">Docs</a>
          <a href="https://github.com/open-ma/open-managed-agents">GitHub</a>
          <a href="/blog/rss.xml">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
