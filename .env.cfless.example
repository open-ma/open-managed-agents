# Required for harness turns (any Anthropic-compatible API key).
ANTHROPIC_API_KEY=sk-...

# Optional: point at an Anthropic-compatible proxy. The SDK appends
# `/messages` to whatever you set, so include `/v1` (provider.ts will
# append /v1 automatically if missing — but being explicit is clearer).
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: extra HTTP headers comma-separated. Used when the proxy
# requires e.g. a sub-module gating header.
# ANTHROPIC_CUSTOM_HEADERS=X-Sub-Module: my-module

# Optional: override the listening port (host side). Defaults to 8787.
# OMA_PORT=8787
